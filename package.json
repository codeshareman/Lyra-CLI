{
  "name": "@captain_z/lyra",
  "version": "1.0.1",
  "description": "Universal content generation framework with plugin-based architecture",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lyra": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:unit": "jest --testPathPattern=\\.test\\.ts$",
    "test:property": "jest --testPathPattern=\\.property\\.ts$",
    "test:coverage": "jest --coverage",
    "check:image-hosts": "node scripts/check-image-hosts.js",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lyra",
    "template",
    "obsidian",
    "weekly",
    "newsletter",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist/**/*",
    "templates/**/*",
    "README.md",
    "README.zh-CN.md",
    "CLI_GUIDE.md",
    "QUICK_START.md",
    "docs/**/*",
    "schemas/**/*"
  ],
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^11.1.0",
    "cosmiconfig": "^9.0.0",
    "cron-parser": "^4.9.0",
    "date-fns": "^3.0.6",
    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "minimatch": "^9.0.3",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.37",
    "@types/node-cron": "^3.0.11",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeshareman/Lyra.git"
  },
  "homepage": "https://github.com/codeshareman/Lyra#readme",
  "bugs": {
    "url": "https://github.com/codeshareman/Lyra/issues"
  }
}
