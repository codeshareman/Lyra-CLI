---
id: {{{yamlString metadata.id}}}
title: {{{yamlString metadata.title}}}
type: {{{yamlString metadata.type}}}
issue_number: {{metadata.issueNumber}}
date: {{{yamlString (formatDate metadata.date "yyyy-MM-dd")}}}
week_start: {{{yamlString (formatDate metadata.weekStart "yyyy-MM-dd")}}}
week_end: {{{yamlString (formatDate metadata.weekEnd "yyyy-MM-dd")}}}
created: {{{yamlString (formatDate metadata.created "yyyy-MM-dd HH:mm:ss")}}}
modified: {{{yamlString (formatDate metadata.modified "yyyy-MM-dd HH:mm:ss")}}}
status: {{{yamlString metadata.status}}}
tags: {{#if metadata.tags}}[{{#each metadata.tags}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]{{else}}[]{{/if}}
published_platforms: {{#if metadata.publishedPlatforms}}[{{#each metadata.publishedPlatforms}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}}]{{else}}[]{{/if}}
{{#if metadata.coverImage}}
cover_image: {{{yamlString metadata.coverImage}}}
{{/if}}
{{#if metadata.backgroundImage}}
background_image: {{{yamlString metadata.backgroundImage}}}
{{/if}}
{{#if metadata.goldenQuote}}
golden_quote:
  content: {{{yamlString metadata.goldenQuote.content}}}
  author: {{{yamlString metadata.goldenQuote.author}}}
{{/if}}
---

# {{#if metadata.brandTitle}}{{uppercase metadata.brandTitle}}{{else}}Z°N VOYAGE LOG{{/if}}

## ISSUE #{{padStart metadata.issueNumber 3 "0"}}

