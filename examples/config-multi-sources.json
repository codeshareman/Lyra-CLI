{
  "description": "Configuration example with multiple data sources and priorities",
  "global": {
    "logLevel": "info",
    "defaultTemplate": "weekly"
  },
  "templates": {
    "weekly": {
      "enabled": true,
      "template": {
        "path": "./templates/weekly.hbs"
      },
      "sources": {
        "articles": [
          {
            "path": "./Clippings/Tech",
            "include": ["**/*.md"],
            "exclude": ["**/Archive/**"],
            "priority": 2,
            "alias": "tech-articles"
          },
          {
            "path": "./Clippings/Business",
            "include": ["**/*.md"],
            "priority": 1,
            "alias": "business-articles"
          },
          {
            "path": "./ReadingList",
            "priority": 0
          }
        ],
        "tools": [
          {
            "path": "./Tools/Development",
            "priority": 2
          },
          {
            "path": "./Tools/Productivity",
            "priority": 1
          },
          "./Tools/Other"
        ],
        "notes": [
          {
            "path": "./Permanent Notes/Tech",
            "priority": 1
          },
          "./Permanent Notes/General"
        ]
      },
      "output": {
        "path": "./Weekly",
        "filename": "Weekly-{{issueNumber}}.md"
      },
      "content": {
        "articles": {
          "topN": 15,
          "minRating": 2
        },
        "tools": {
          "perCategory": 2
        },
        "notes": {
          "groupBy": "category"
        }
      }
    }
  }
}
