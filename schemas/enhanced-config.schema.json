{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/content-generator/schemas/enhanced-config.schema.json",
  "title": "Content Generator Enhanced Weekly Config",
  "description": "JSON Schema for enhanced weekly template configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["global", "templates"],
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logLevel", "defaultTemplate"],
      "properties": {
        "logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warning", "error"],
          "description": "Global log level"
        },
        "defaultTemplate": {
          "type": "string",
          "description": "Default template key to generate"
        }
      }
    },
    "templates": {
      "type": "object",
      "minProperties": 1,
      "description": "Template map by template name",
      "additionalProperties": {
        "$ref": "#/definitions/templateConfig"
      }
    }
  },
  "definitions": {
    "dateLike": {
      "oneOf": [
        {
          "type": "string",
          "format": "date"
        },
        {
          "type": "string",
          "format": "date-time"
        }
      ]
    },
    "dataSourceObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Source path (relative or absolute)"
        },
        "include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Glob include patterns"
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Glob exclude patterns"
        },
        "priority": {
          "type": "number",
          "description": "Source priority for deduplication"
        },
        "alias": {
          "type": "string",
          "description": "Source alias used in output metadata"
        }
      }
    },
    "dataSourceInput": {
      "description": "A source can be a path string, an object, or an array of source objects",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/definitions/dataSourceObject"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/dataSourceObject"
          }
        }
      ]
    },
    "filterCriteria": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dateRange": {
          "type": "object",
          "additionalProperties": false,
          "required": ["start", "end"],
          "properties": {
            "start": {
              "$ref": "#/definitions/dateLike"
            },
            "end": {
              "$ref": "#/definitions/dateLike"
            }
          }
        },
        "minRating": {
          "type": "number"
        }
      }
    },
    "moduleConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "icon": {
          "type": "string"
        },
        "filter": {
          "$ref": "#/definitions/filterCriteria"
        }
      }
    },
    "templateConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "template", "sources", "output", "content"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "templateVersion": {
          "type": "string",
          "enum": ["legacy", "enhanced"],
          "description": "Template mode selector"
        },
        "template": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": {
              "type": "string",
              "description": "Handlebars template path"
            }
          }
        },
        "hooks": {
          "type": "object",
          "description": "Hook script paths",
          "additionalProperties": {
            "type": "string"
          }
        },
        "sources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["articles", "tools", "notes"],
          "properties": {
            "articles": {
              "$ref": "#/definitions/dataSourceInput"
            },
            "tools": {
              "$ref": "#/definitions/dataSourceInput"
            },
            "notes": {
              "$ref": "#/definitions/dataSourceInput"
            },
            "life": {
              "$ref": "#/definitions/dataSourceInput"
            },
            "food": {
              "$ref": "#/definitions/dataSourceInput"
            },
            "exercise": {
              "$ref": "#/definitions/dataSourceInput"
            },
            "music": {
              "$ref": "#/definitions/dataSourceInput"
            }
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "filename"],
          "properties": {
            "path": {
              "type": "string"
            },
            "filename": {
              "type": "string"
            }
          }
        },
        "content": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "articles": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "topN": {
                  "type": "integer",
                  "minimum": 1
                },
                "minRating": {
                  "type": "number",
                  "minimum": 0
                }
              }
            },
            "tools": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "perCategory": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            },
            "notes": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "groupBy": {
                  "type": "string",
                  "enum": ["tags", "category", "none"]
                }
              }
            }
          }
        },
        "visual": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "coverImage": {
              "type": "string",
              "description": "Cover image URL or local path"
            },
            "backgroundImage": {
              "type": "string",
              "description": "Background image URL or local path"
            },
            "goldenQuote": {
              "type": "object",
              "additionalProperties": false,
              "required": ["content", "author"],
              "properties": {
                "content": {
                  "type": "string",
                  "minLength": 1
                },
                "author": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "modules": {
          "type": "object",
          "description": "Module-level enable and filter settings",
          "additionalProperties": {
            "$ref": "#/definitions/moduleConfig"
          },
          "properties": {
            "weeklyUpdates": {
              "$ref": "#/definitions/moduleConfig"
            },
            "reading": {
              "$ref": "#/definitions/moduleConfig"
            },
            "tech": {
              "$ref": "#/definitions/moduleConfig"
            },
            "life": {
              "$ref": "#/definitions/moduleConfig"
            },
            "products": {
              "$ref": "#/definitions/moduleConfig"
            },
            "food": {
              "$ref": "#/definitions/moduleConfig"
            },
            "exercise": {
              "$ref": "#/definitions/moduleConfig"
            },
            "music": {
              "$ref": "#/definitions/moduleConfig"
            },
            "thoughts": {
              "$ref": "#/definitions/moduleConfig"
            }
          }
        },
        "export": {
          "type": "object",
          "additionalProperties": false,
          "required": ["formats"],
          "properties": {
            "formats": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["markdown", "html", "wechat"]
              }
            },
            "wechat": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "validateImages": {
                  "type": "boolean"
                },
                "backgroundPreset": {
                  "type": "string",
                  "enum": ["grid", "warm", "plain"]
                },
                "theme": {
                  "type": "string",
                  "enum": [
                    "industrial",
                    "magazine-editorial",
                    "magazine-bold",
                    "newspaper-classic",
                    "minimal-clean",
                    "modernist-print",
                    "tech-spec"
                  ]
                },
                "imageProxyUrl": {
                  "type": "string",
                  "description": "Image proxy template URL, use {url} placeholder"
                },
                "inaccessibleImageDomains": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "imageOptimization": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "maxWidth": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "quality": {
                      "type": "number",
                      "minimum": 1,
                      "maximum": 100
                    },
                    "format": {
                      "type": "string",
                      "enum": ["auto", "webp", "jpeg", "png"]
                    }
                  }
                }
              }
            }
          }
        },
        "ai": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "provider": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "apiKey": {
              "type": "string"
            },
            "summaries": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "maxLength": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          }
        }
      },
      "examples": [
        {
          "enabled": true,
          "templateVersion": "enhanced",
          "template": {
            "path": "./templates/weekly.hbs"
          },
          "sources": {
            "articles": "./Clippings",
            "tools": "./Tools",
            "notes": "./Permanent Notes",
            "life": "./Life"
          },
          "output": {
            "path": "./Weekly",
            "filename": "Enhanced-Weekly-{{issueNumber}}.md"
          },
          "content": {
            "articles": {
              "topN": 20,
              "minRating": 3
            }
          },
          "visual": {
            "coverImage": "https://example.com/cover.jpg",
            "goldenQuote": {
              "content": "Consistency beats intensity.",
              "author": "Team"
            }
          },
          "export": {
            "formats": ["markdown", "wechat"],
            "wechat": {
              "validateImages": true,
              "imageProxyUrl": "https://images.weserv.nl/?url={url}",
              "imageOptimization": {
                "maxWidth": 1200,
                "quality": 80,
                "format": "webp"
              }
            }
          }
        }
      ]
    }
  }
}
