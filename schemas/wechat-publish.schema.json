{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.lyra.dev/wechat-publish.schema.json",
  "title": "Lyra WeChat Publish Config",
  "description": "Lyra WeChat 发布配置（wechat_publish.json）",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "lyraConfig": { "type": "string", "description": "Lyra 配置文件路径（.lyrarc.json）" },
    "title": { "type": "string", "description": "默认标题（所有文章缺省值）" },
    "author": { "type": "string", "description": "默认作者（所有文章缺省值）" },
    "digest": { "type": "string", "description": "默认摘要（所有文章缺省值）" },
    "thumb_image_path": { "type": "string", "description": "默认封面图路径（本地）" },
    "thumb_image_url": { "type": "string", "description": "默认封面图 URL（远程）" },
    "articles": {
      "type": "array",
      "description": "发布文章列表",
      "items": { "$ref": "#/definitions/wechatArticle" }
    }
  },
  "required": ["articles"],
  "definitions": {
    "wechatArticle": {
      "type": "object",
      "description": "单篇发布文章配置",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string", "description": "文章标题" },
        "author": { "type": "string", "description": "文章作者" },
        "digest": { "type": "string", "description": "文章摘要" },
        "module": { "type": "string", "description": "模块 key（用于匹配提示词/封面规则）" },
        "contentFile": { "type": "string", "description": "文章 HTML/Markdown 文件路径" },
        "content": { "type": "string", "description": "文章内容（直接写入）" },
        "thumb_media_id": { "type": "string", "description": "微信公众号素材 ID（优先级最高）" },
        "thumb_image_path": { "type": "string", "description": "封面图路径（本地）" },
        "thumb_image_url": { "type": "string", "description": "封面图 URL（远程）" },
        "cover_prompt": { "type": "string", "description": "封面生成提示词（可选）" },
        "cover_ratio": { "type": "string", "description": "封面比例（如 16:9 / 4:3）" }
      }
    }
  }
}
